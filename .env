# ShieldPanel Environment Configuration

# Database Configuration
POSTGRES_USER=shieldpanel_user
POSTGRES_PASSWORD=shieldpanel_secure_pass
POSTGRES_DB=shieldpanel
DB_HOST=postgres
DB_PORT=5432

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=shieldpanel_mq
RABBITMQ_DEFAULT_PASS=shieldpanel_mq_pass
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Port Exposures to Host
HOST_WEB_PORT=8089
HOST_RABBIT_MGMT_PORT=15672

# Log Files Configuration
ACCESS_LOG_PATH=/shared/logs/access.log
ERROR_LOG_PATH=/shared/logs/error.log
